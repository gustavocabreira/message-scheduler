APP_NAME="Message Scheduler"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://api.localhost.com
APP_TIMEZONE=UTC

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# ── Database (PostgreSQL) ────────────────────────────────────────────────────
DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=message_scheduler
DB_USERNAME=postgres
DB_PASSWORD=secret

# ── Session ──────────────────────────────────────────────────────────────────
SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

# ── Broadcast / Filesystem ───────────────────────────────────────────────────
BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local

# ── Queues ───────────────────────────────────────────────────────────────────
QUEUE_CONNECTION=redis
HORIZON_PREFIX=message_scheduler

# ── Cache ────────────────────────────────────────────────────────────────────
CACHE_STORE=redis

# ── Redis ────────────────────────────────────────────────────────────────────
REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

# ── Mail ─────────────────────────────────────────────────────────────────────
MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# ── Huggy OAuth2 ─────────────────────────────────────────────────────────────
HUGGY_CLIENT_ID=
HUGGY_CLIENT_SECRET=
HUGGY_REDIRECT_URI=
HUGGY_API_BASE_URL=https://api.huggy.app

# ── Sentry (produção) ────────────────────────────────────────────────────────
SENTRY_LARAVEL_DSN=